Algoritmo SistemaOperativo
	Definir opcionn Como Caracter
	Imprimir ( "ingrese un caracter: " )
	leer opcionn 
	Imprimir ( "su opcion es " )
	si( opcionn == 'a' o opcionn == 'A' ) Entonces
		Imprimir  "Android"
	SiNo
		
		si( opcionn == 'i' o opcionn == 'I' ) Entonces
			Imprimir "Ios"
		SiNo
			Imprimir "invalida"
		FinSi
		
	FinSi
FinAlgoritmo
