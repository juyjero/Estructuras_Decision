Algoritmo NumeroPrimo
	
	Definir num Como Entero
	
	Imprimir "Ingrese un numero entre 0 y 20: "
	Leer num
	
	Si num = 2 O num = 3 O num = 5 O num = 7 O num = 11 O num = 13 O num = 17 O num = 19 Entonces
		
		Imprimir "Es un numero primo"
		
	SiNo
		
		Imprimir "No es un numero primo"
		
	FinSi
	
FinAlgoritmo