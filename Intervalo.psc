Algoritmo Intervalo
	
	Definir minimoValor, maximoValor, x Como real
	
	Imprimir "Ingrese el valor minimo: "
	Leer minimoValor
	
	Imprimir "Ingrese el valor maximo: "
	Leer maximoValor
	
	Imprimir "Ingrese el valor x: "
	Leer x
	
	Si x >= minimoValor Y x <= maximoValor Entonces
		Imprimir "El numero esta dentro del intervalo"
	SiNo
		Imprimir "El numero esta fuera del intervalo"
	FinSi
	
FinAlgoritmo
