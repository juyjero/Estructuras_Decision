Algoritmo MayorNumero
    Definir n1, n2, mayor Como Entero
    
    Escribir "Ingrese el primer numero: "
    Leer n1
    
    Escribir "Ingrese el segundo numero: "
    Leer n2
    
    Si n1 > n2 Entonces
        mayor = n1
    SiNo
        mayor = n2
    FinSi
    
    Escribir "El mayor es: ", mayor
FinAlgoritmo